<%- include('../partials/header', { title: event.name + ' - SG' }) %>

<div class="page-header">
  <h1>SG — <%= event.name %></h1>
  <a href="/events/<%= event.id %>" class="btn">← Back to Event</a>
</div>

<div class="form-entry-layout">
  <div class="card form-card">
    <h2>New Entry</h2>
    <form action="/events/<%= event.id %>/forms/sg" method="POST" class="form">
      <div class="form-group">
        <label for="operator_id">Operator (who filled this form)</label>
        <select id="operator_id" name="operator_id" required>
          <option value="">-- Select Operator --</option>
          <% operators.forEach(op => { %>
            <option value="<%= op.id %>"><%= op.name %></option>
          <% }) %>
        </select>
        <% if (operators.length === 0) { %>
          <p class="text-warning">No SG operators created. <a href="/operators">Add operators first</a>.</p>
        <% } %>
      </div>
      <div class="form-row">
        <div class="form-group">
          <label for="serial_number">S/N (Serial Number)</label>
          <input type="text" id="serial_number" name="serial_number" required>
        </div>
        <div class="form-group">
          <label for="subject_id">Subject ID</label>
          <input type="text" id="subject_id" name="subject_id" required>
        </div>
      </div>

      <fieldset class="fieldset">
        <legend>Equipment Numbers</legend>
        <div class="form-row">
          <div class="form-group">
            <label for="hba1c_equip_no">HbA1C Equipment No.</label>
            <input type="text" id="hba1c_equip_no" name="hba1c_equip_no" required>
          </div>
          <div class="form-group">
            <label for="cholesterol_equip_no">Cholesterol Equipment No.</label>
            <input type="text" id="cholesterol_equip_no" name="cholesterol_equip_no" required>
          </div>
        </div>
      </fieldset>

      <fieldset class="fieldset">
        <legend>Blood Results</legend>
        <div class="form-row">
          <div class="form-group">
            <label for="hba1c">HbA1C (%)</label>
            <input type="number" id="hba1c" name="hba1c" step="0.1" min="0" required>
          </div>
          <div class="form-group">
            <label for="total_cholesterol">Total Cholesterol (mmol/L)</label>
            <input type="number" id="total_cholesterol" name="total_cholesterol" step="0.1" min="0" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="hdl">HDL (mmol/L)</label>
            <input type="number" id="hdl" name="hdl" step="0.1" min="0" required>
          </div>
          <div class="form-group">
            <label for="trig">TRIG (mmol/L)</label>
            <input type="number" id="trig" name="trig" step="0.1" min="0" required>
          </div>
        </div>
        <div class="form-row">
          <div class="form-group">
            <label for="ldl">LDL (mmol/L)</label>
            <input type="number" id="ldl" name="ldl" step="0.1" min="0" required>
          </div>
          <div class="form-group">
            <label for="glucose_donutech">Glucose (DonuTech) (mmol/L)</label>
            <input type="number" id="glucose_donutech" name="glucose_donutech" step="0.1" min="0" required>
          </div>
        </div>
      </fieldset>

      <div class="form-group">
        <label for="remarks">Remarks</label>
        <textarea id="remarks" name="remarks" rows="2"></textarea>
      </div>
      <button type="submit" class="btn btn-primary btn-block">Save Entry</button>
    </form>
  </div>

  <div class="card records-card">
    <h2>Records (<%= records.length %>)</h2>
    <% if (records.length === 0) { %>
      <p class="text-muted">No records yet.</p>
    <% } else { %>
      <div class="table-scroll">
        <table class="table">
          <thead>
            <tr>
              <th>S/N</th>
              <th>Subject ID</th>
              <th>HbA1C</th>
              <th>Chol</th>
              <th>HDL</th>
              <th>TRIG</th>
              <th>LDL</th>
              <th>Gluc(DT)</th>
              <th>Operator</th>
              <th></th>
            </tr>
          </thead>
          <tbody>
            <% records.forEach(r => { %>
              <tr>
                <td><%= r.serial_number %></td>
                <td><%= r.subject_id %></td>
                <td><%= r.hba1c %></td>
                <td><%= r.total_cholesterol %></td>
                <td><%= r.hdl %></td>
                <td><%= r.trig %></td>
                <td><%= r.ldl %></td>
                <td><%= r.glucose_donutech %></td>
                <td><%= r.operator_name %></td>
                <td>
                  <form action="/events/<%= event.id %>/records/sg_records/<%= r.id %>?_method=DELETE" method="POST" onsubmit="return confirm('Delete?')">
                    <button class="btn btn-sm btn-danger">✕</button>
                  </form>
                </td>
              </tr>
            <% }) %>
          </tbody>
        </table>
      </div>
    <% } %>
  </div>
</div>
</main>
</body>
</html>

<%- include('partials/header', { title: 'Events' }) %>

<h1>Data Collection Events</h1>
<a href="/events/new" class="btn btn-primary">+ New Event</a>

<% if (events.length === 0) { %>
  <p class="empty-state">No events yet. Create one to get started.</p>
<% } else { %>
  <table class="table">
    <thead>
      <tr>
        <th>Name</th>
        <th>Date</th>
        <th>Status</th>
        <th>Actions</th>
      </tr>
    </thead>
    <tbody>
      <% events.forEach(e => { %>
        <tr>
          <td><a href="/events/<%= e.id %>"><%= e.name %></a></td>
          <td><%= e.event_date %></td>
          <td><span class="badge badge-<%= e.status %>"><%= e.status %></span></td>
          <td>
            <a href="/events/<%= e.id %>" class="btn btn-sm">View</a>
            <form action="/events/<%= e.id %>?_method=DELETE" method="POST" style="display:inline" onsubmit="return confirm('Delete this event and all its data?')">
              <button class="btn btn-sm btn-danger">Delete</button>
            </form>
          </td>
        </tr>
      <% }) %>
    </tbody>
  </table>
<% } %>
</main>
</body>
</html>
